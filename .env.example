# FreshBhoj Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/freshbhoj?schema=public"

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ─── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here_change_in_prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here_change_in_prod
JWT_REFRESH_EXPIRY=30d

# ─── Twilio (OTP via SMS) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# OR use Twilio Verify Service (recommended):
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OTP Config ────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6
# Set to true in dev to skip real SMS (use fixed OTP: 123456)
OTP_DEV_MODE=true

# ─── AWS S3 (Profile Images / Video Storage) ───────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=freshbhoj-media
AWS_S3_CDN_URL=https://your-cloudfront-url.cloudfront.net

# ─── App ───────────────────────────────────────────────────────
APP_NAME=FreshBhoj
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
